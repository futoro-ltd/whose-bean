# Database Configuration
# Choose your database by setting USE_POSTGRES to true or false

# For SQLite (default):
USE_POSTGRES=false
DATABASE_URL="file:./dev.db"

# For PostgreSQL:
# USE_POSTGRES=true
# DATABASE_URL="postgresql://username:password@host:5432/database"

# Authentication
JWT_SECRET="your-secret-key-change-in-production"

# Email Configuration (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@whosebean.com"

# App URL
APP_URL="http://localhost:9500"

# Server Actions - comma-separated origins (default: *, i.e., allow all)
# ALLOWED_ORIGINS="*.example.com,localhost"

# Analytics Bot Handling
# Options: 'filter' (default), 'mark', or 'log'
# filter: Don't store analytics data from detected bots
# mark: Store but flag as bot traffic (adds isBot: true)
# log: Log bot detection but store data normally
ANALYTICS_BOT_HANDLING=filter

# This is not crucial, but to avoid errors in you log, as you are not 
# deploying to Vercel, add this variable.
# The log erros may look something like this:
#   Error: Failed to find Server Action "x". This request might be from an older or newer deployment.
# You can use: 
#   openssl rand -base64 32
# to create a 32 byte encryption.
# For more details, see https://nextjs.org/docs/messages/failed-to-find-server-action
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="your-secret-key-change-in-production"